{
  "name": "@ui/style",
  "version": "1.0.0",
  "main": "tailwind.config.js",
  "private": true,
  "exports": {
    ".": "./tailwind.config.js",
    "./dist/style.css": "./dist/style.css",
    "./tokens-config": "./src/tokens-config.js"
  },
  "scripts": {
    "generate:tokens": "node scripts/generate-tokens.js",
    "dev": "concurrently \"node scripts/watch-tokens.js\" \"tailwindcss -i ./src/style.css -o ./dist/style.css --watch\"",
    "build": "npm run generate:tokens && tailwindcss -i ./src/style.css -o ./dist/style.css --minify"
  },
  "devDependencies": {
    "autoprefixer": "^10.5.0",
    "chokidar": "^3.6.0",
    "concurrently": "^9.0.0",
    "postcss": "^8.5.14",
    "tailwindcss": "3.4",
    "tailwindcss-animate": "^1.0.7"
  }
}