{
  "name": "vue-workspace",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -n style,vue -c blue,green \"npm run dev -w @ui/style\" \"npm run dev -w @ui/vue\"",
    "build": "npm run build -w @ui/style"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "concurrently": "^9.0.0",
    "eslint": "^10.4.1",
    "eslint-plugin-vue": "^10.9.1",
    "typescript-eslint": "^8.60.0",
    "vue-eslint-parser": "^10.4.0"
  }
}